{
  "JS Advanced - Promise Basic": {
    "scope": "javascript",
    "prefix": "edu-promise",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - PROMISE DASAR",
      "// ======================================",
      "const ${1:fetchData} = new Promise((resolve, reject) => {",
      "  const ${2:success} = ${3:true};",
      "",
      "  setTimeout(() => {",
      "    if (${2:success}) {",
      "      resolve(\"${4:Data berhasil diambil}\");",
      "    } else {",
      "      reject(\"${5:Terjadi kesalahan}\");",
      "    }",
      "  }, ${6:2000});",
      "});",
      "",
      "${1:fetchData}",
      "  .then(result => { console.log(result); })",
      "  .catch(error => { console.error(error); });",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Promise = objek untuk operasi asynchronous",
      "// resolve() dipanggil jika berhasil",
      "// reject()  dipanggil jika gagal",
      "// .then()   menangani hasil sukses",
      "// .catch()  menangani error",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP tidak punya Promise built-in",
      "// PHP 8.1+ punya Fiber untuk async programming"
    ],
    "description": "Promise dasar JavaScript + penjelasan"
  },
  "JS Advanced - Async Await": {
    "scope": "javascript",
    "prefix": "edu-async",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - ASYNC/AWAIT",
      "// ======================================",
      "async function ${1:getData}() {",
      "  try {",
      "    const ${2:response} = await fetch('${3:https://api.example.com/data}');",
      "    const ${4:data} = await ${2:response}.json();",
      "    console.log(${4:data});",
      "    return ${4:data};",
      "  } catch (error) {",
      "    console.error('${5:Error}:', error);",
      "  }",
      "}",
      "",
      "${1:getData}();",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// async  = function ini return Promise",
      "// await  = tunggu Promise selesai (hanya di async function)",
      "// try/catch = tangani error seperti .catch() di Promise",
      "",
      "// ======================================",
      "// KEUNTUNGAN vs .then()",
      "// ======================================",
      "// - Kode lebih mudah dibaca (seperti synchronous)",
      "// - Error handling lebih jelas dengan try/catch",
      "// - Menghindari 'callback hell'",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP secara default adalah synchronous",
      "// PHP 8.1+ punya Fiber untuk async operations"
    ],
    "description": "Async/await JavaScript + penjelasan lengkap"
  },
  "JS Advanced - Destructuring Object": {
    "scope": "javascript",
    "prefix": "edu-destructure-obj",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - DESTRUCTURING OBJECT",
      "// ======================================",
      "const ${1:user} = {",
      "  ${2:nama}: \"${3:Andi}\",",
      "  ${4:umur}: ${5:20},",
      "  ${6:kota}: \"${7:Jakarta}\"",
      "};",
      "",
      "// Ambil properti langsung",
      "const { ${2:nama}, ${4:umur} } = ${1:user};",
      "console.log(${2:nama}); // \"${3:Andi}\"",
      "",
      "// Dengan alias (rename)",
      "const { ${2:nama}: ${8:namaLengkap} } = ${1:user};",
      "",
      "// Dengan default value",
      "const { ${9:email} = \"${10:tidak ada}\" } = ${1:user};",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Destructuring = ekstrak nilai dari object/array",
      "// Lebih singkat daripada user.nama, user.umur",
      "// Bisa pakai alias dan default value",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP 7.1+: ['nama' => $n] = $user;",
      "// Tapi tidak sefleksibel JavaScript"
    ],
    "description": "Object destructuring JavaScript + penjelasan"
  },
  "JS Advanced - Destructuring Array": {
    "scope": "javascript",
    "prefix": "edu-destructure-arr",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - DESTRUCTURING ARRAY",
      "// ======================================",
      "const ${1:warna} = [\"${2:merah}\", \"${3:hijau}\", \"${4:biru}\"];",
      "",
      "// Ambil nilai berdasarkan posisi",
      "const [${5:pertama}, ${6:kedua}] = ${1:warna};",
      "console.log(${5:pertama}); // \"${2:merah}\"",
      "",
      "// Skip element dengan koma",
      "const [, , ${7:ketiga}] = ${1:warna};",
      "console.log(${7:ketiga}); // \"${4:biru}\"",
      "",
      "// Rest operator (...)",
      "const [${8:first}, ...${9:sisanya}] = ${1:warna};",
      "console.log(${9:sisanya}); // [\"${3:hijau}\", \"${4:biru}\"]",
      "",
      "// Swap variable",
      "let ${10:a} = ${11:1}, ${12:b} = ${13:2};",
      "[${10:a}, ${12:b}] = [${12:b}, ${10:a}];",
      "console.log(${10:a}, ${12:b}); // 2 1",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Destructuring array berdasarkan urutan/posisi",
      "// Rest operator (...) menampung sisa element",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP: [$a, $b] = [1, 2];",
      "// Tapi tidak punya rest operator seperti JS"
    ],
    "description": "Array destructuring JavaScript + penjelasan"
  },
  "JS Advanced - Spread Operator": {
    "scope": "javascript",
    "prefix": "edu-spread",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - SPREAD OPERATOR",
      "// ======================================",
      "",
      "// 1. Spread Array",
      "const ${1:arr1} = [${2:1}, ${3:2}, ${4:3}];",
      "const ${5:arr2} = [${6:4}, ${7:5}];",
      "const ${8:gabung} = [...${1:arr1}, ...${5:arr2}];",
      "console.log(${8:gabung}); // [1, 2, 3, 4, 5]",
      "",
      "// 2. Copy array",
      "const ${9:copy} = [...${1:arr1}];",
      "",
      "// 3. Spread Object",
      "const ${10:user} = { ${11:nama}: \"${12:Andi}\", ${13:umur}: ${14:20} };",
      "const ${15:updated} = { ...${10:user}, ${13:umur}: ${16:21} };",
      "console.log(${15:updated}); // { nama: 'Andi', umur: 21 }",
      "",
      "// 4. Spread di function argument",
      "const ${17:angka} = [${18:10}, ${19:20}, ${20:30}];",
      "console.log(Math.max(...${17:angka})); // 30",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Spread (...) 'membuka' array/object",
      "// Berguna untuk merge, copy, pass arguments",
      "// Hati-hati: hanya shallow copy",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP 7.4+: $gabung = [...$arr1, ...$arr2];",
      "// Untuk object PHP pakai array_merge() atau +"
    ],
    "description": "Spread operator JavaScript + penjelasan"
  },
  "JS Advanced - Rest Parameter": {
    "scope": "javascript",
    "prefix": "edu-rest",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - REST PARAMETER",
      "// ======================================",
      "",
      "// Function dengan rest parameter",
      "function ${1:jumlah}(...${2:angka}) {",
      "  return ${2:angka}.reduce((total, num) => total + num, 0);",
      "}",
      "",
      "console.log(${1:jumlah}(${3:1}, ${4:2}, ${5:3})); // 6",
      "console.log(${1:jumlah}(${6:10}, ${7:20}));       // 30",
      "",
      "// Kombinasi parameter biasa + rest",
      "function ${8:greet}(${9:salam}, ...${10:nama}) {",
      "  return `${9:salam} ${${10:nama}.join(', ')}`;",
      "}",
      "console.log(${8:greet}(\"${11:Halo}\", \"${12:Andi}\", \"${13:Budi}\"));",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Rest (...) mengumpulkan arguments jadi array",
      "// REST  = 'kumpulkan' (di parameter function)",
      "// SPREAD = 'sebarkan' (di argument pemanggilan)",
      "// Rest parameter harus di posisi TERAKHIR",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP 5.6+: function jumlah(...$angka) { return array_sum($angka); }",
      "// Konsepnya identik dengan JavaScript"
    ],
    "description": "Rest parameter JavaScript + penjelasan"
  },
  "JS Advanced - Template Literals": {
    "scope": "javascript",
    "prefix": "edu-template",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - TEMPLATE LITERALS",
      "// ======================================",
      "const ${1:nama} = \"${2:Andi}\";",
      "const ${3:umur} = ${4:20};",
      "",
      "// 1. String interpolation",
      "const ${5:pesan} = `Halo, saya ${1:nama} umur ${3:umur} tahun`;",
      "console.log(${5:pesan});",
      "",
      "// 2. Multi-line string (tanpa \\n)",
      "const ${6:alamat} = `",
      "  Jalan ${7:Merdeka} No. ${8:10}",
      "  Kota ${9:Jakarta}",
      "`;",
      "",
      "// 3. Expression di dalam template",
      "const ${10:harga} = ${11:100000};",
      "const ${12:diskon} = ${13:0.1};",
      "console.log(`Harga setelah diskon: ${${10:harga} * (1 - ${12:diskon})}`);",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Template literals menggunakan backtick (`)",
      "// ${...} untuk interpolasi variable/expression",
      "// Mendukung multi-line tanpa escape character",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP double-quote: \"Halo $nama, umur $umur\"",
      "// PHP complex: \"Harga: {$harga * 0.9}\"",
      "// PHP heredoc untuk multi-line string"
    ],
    "description": "Template literals JavaScript + penjelasan lengkap"
  },
  "JS Advanced - Promise Chain": {
    "scope": "javascript",
    "prefix": "edu-promise-chain",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - PROMISE CHAINING",
      "// ======================================",
      "function ${1:step1}() {",
      "  return new Promise(resolve => {",
      "    setTimeout(() => resolve(\"${2:Step 1 selesai}\"), ${3:1000});",
      "  });",
      "}",
      "",
      "function ${4:step2}(${5:data}) {",
      "  return new Promise(resolve => {",
      "    setTimeout(() => resolve(`${${5:data}} → Step 2`), ${6:1000});",
      "  });",
      "}",
      "",
      "${1:step1}()",
      "  .then(result1 => {",
      "    console.log(result1);",
      "    return ${4:step2}(result1);",
      "  })",
      "  .then(result2 => { console.log(result2); })",
      "  .catch(error => { console.error('Error:', error); });",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Promise chaining = .then() berturut-turut",
      "// Setiap .then() harus return Promise untuk lanjut chain",
      "// .catch() menangkap error dari promise manapun di chain",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN ASYNC/AWAIT",
      "// ======================================",
      "// async function run() {",
      "//   const r1 = await step1();",
      "//   const r2 = await step2(r1);",
      "//   console.log(r2);",
      "// }"
    ],
    "description": "Promise chaining + penjelasan"
  },
  "JS Advanced - Promise All": {
    "scope": "javascript",
    "prefix": "edu-promise-all",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - PROMISE.ALL",
      "// ======================================",
      "",
      "// Jalankan semua promise secara PARALLEL",
      "async function ${1:getAllData}() {",
      "  try {",
      "    const [${2:user1}, ${3:user2}, ${4:user3}] = await Promise.all([",
      "      fetch('${5:https://api.example.com/user/1}').then(r => r.json()),",
      "      fetch('${6:https://api.example.com/user/2}').then(r => r.json()),",
      "      fetch('${7:https://api.example.com/user/3}').then(r => r.json())",
      "    ]);",
      "",
      "    console.log({ ${2:user1}, ${3:user2}, ${4:user3} });",
      "  } catch (error) {",
      "    // Jika salah satu gagal, semua gagal",
      "    console.error('Ada yang error:', error);",
      "  }",
      "}",
      "",
      "${1:getAllData}();",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Promise.all() = jalankan multiple promises parallel",
      "// Tunggu sampai SEMUA selesai",
      "// Jika 1 reject, langsung gagal semua",
      "// Lebih cepat daripada await satu per satu",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN ALTERNATIF LAIN",
      "// ======================================",
      "// Promise.allSettled() - tunggu semua, terlepas sukses/gagal",
      "// Promise.race()       - ambil yang paling cepat",
      "// Promise.any()        - ambil yang pertama sukses"
    ],
    "description": "Promise.all untuk parallel execution + penjelasan"
  },
  "JS Advanced - Class ES6": {
    "scope": "javascript",
    "prefix": "edu-js-class",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - CLASS ES6",
      "// ======================================",
      "",
      "class ${1:User} {",
      "  // Private field (ES2022+)",
      "  #${2:nama};",
      "  #${3:email};",
      "",
      "  constructor(${4:nama}, ${5:email}) {",
      "    this.#${2:nama} = ${4:nama};",
      "    this.#${3:email} = ${5:email};",
      "  }",
      "",
      "  // Getter",
      "  get ${6:nama}() { return this.#${2:nama}; }",
      "",
      "  // Method",
      "  ${7:info}() {",
      "    return `${8:Nama}: ${this.#${2:nama}}, Email: ${this.#${3:email}}}`;",
      "  }",
      "",
      "  // Static method",
      "  static ${9:create}(${4:nama}, ${5:email}) {",
      "    return new ${1:User}(${4:nama}, ${5:email});",
      "  }",
      "}",
      "",
      "// Inheritance",
      "class ${10:Admin} extends ${1:User} {",
      "  #${11:level};",
      "",
      "  constructor(${4:nama}, ${5:email}, ${12:level}) {",
      "    super(${4:nama}, ${5:email}); // Wajib panggil super()",
      "    this.#${11:level} = ${12:level};",
      "  }",
      "",
      "  ${7:info}() {",
      "    return super.${7:info}() + ` [Admin level: ${this.#${11:level}}]`;",
      "  }",
      "}",
      "",
      "const ${13:user}  = new ${1:User}('${14:Andi}', '${15:andi@example.com}');",
      "const ${16:admin} = new ${10:Admin}('${17:Budi}', '${18:budi@example.com}', ${19:1});",
      "",
      "console.log(${13:user}.${7:info}());",
      "console.log(${16:admin}.${7:info}());",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// class ES6 = sintaks modern OOP di JavaScript",
      "// #field  = private field (tidak bisa diakses dari luar)",
      "// get     = getter property",
      "// static  = method class, bukan method instance",
      "// super() = panggil constructor/method parent",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP: public $nama, private $nama",
      "// JS:  this.nama (public), #nama (private)",
      "// PHP: parent::__construct()",
      "// JS:  super()"
    ],
    "description": "Class ES6 JavaScript + inheritance + penjelasan"
  },
  "JS Advanced - Array Map": {
    "scope": "javascript",
    "prefix": "edu-map",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - ARRAY MAP",
      "// ======================================",
      "const ${1:angka} = [${2:1}, ${3:2}, ${4:3}, ${5:4}, ${6:5}];",
      "",
      "// 1. Map dasar: transformasi setiap elemen",
      "const ${7:dikali2} = ${1:angka}.map(${8:n} => ${8:n} * ${9:2});",
      "console.log(${7:dikali2}); // [2, 4, 6, 8, 10]",
      "",
      "// 2. Map dengan object",
      "const ${10:users} = [",
      "  { ${11:nama}: '${12:Andi}', ${13:umur}: ${14:20} },",
      "  { ${11:nama}: '${15:Budi}', ${13:umur}: ${16:25} }",
      "];",
      "",
      "const ${17:namaList} = ${10:users}.map(${18:u} => ${18:u}.${11:nama});",
      "console.log(${17:namaList}); // ['Andi', 'Budi']",
      "",
      "// 3. Map + format baru",
      "const ${19:formatted} = ${10:users}.map(${18:u} => ({",
      "  ...${18:u},",
      "  ${20:label}: `${${18:u}.${11:nama}} (${${18:u}.${13:umur}} th)`",
      "}));",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// map() = transformasi setiap elemen → array baru",
      "// Tidak mengubah array asli (immutable)",
      "// Selalu return array dengan panjang SAMA",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP: array_map(fn($n) => $n * 2, $angka);",
      "// JS:  angka.map(n => n * 2);",
      "// Bedanya: PHP fungsi dulu, array belakang"
    ],
    "description": "Array map JavaScript + penjelasan + perbandingan PHP"
  },
  "JS Advanced - Array Filter": {
    "scope": "javascript",
    "prefix": "edu-filter",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - ARRAY FILTER",
      "// ======================================",
      "const ${1:angka} = [${2:1}, ${3:2}, ${4:3}, ${5:4}, ${6:5}, ${7:6}];",
      "",
      "// 1. Filter dasar: ambil yang genap",
      "const ${8:genap} = ${1:angka}.filter(${9:n} => ${9:n} % 2 === 0);",
      "console.log(${8:genap}); // [2, 4, 6]",
      "",
      "// 2. Filter dengan object",
      "const ${10:users} = [",
      "  { ${11:nama}: '${12:Andi}', ${13:umur}: ${14:17} },",
      "  { ${11:nama}: '${15:Budi}', ${13:umur}: ${16:20} },",
      "  { ${11:nama}: '${17:Citra}', ${13:umur}: ${18:15} }",
      "];",
      "",
      "const ${19:dewasa} = ${10:users}.filter(${20:u} => ${20:u}.${13:umur} >= ${21:18});",
      "console.log(${19:dewasa}); // [{ nama: 'Budi', umur: 20 }]",
      "",
      "// 3. Filter + Map dikombinasikan",
      "const ${22:namaDewasa} = ${10:users}",
      "  .filter(${20:u} => ${20:u}.${13:umur} >= ${21:18})",
      "  .map(${20:u} => ${20:u}.${11:nama});",
      "console.log(${22:namaDewasa}); // ['Budi']",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// filter() = ambil elemen yang lolos kondisi → array baru",
      "// Return true  → elemen dimasukkan",
      "// Return false → elemen dibuang",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP: array_filter($angka, fn($n) => $n % 2 === 0);",
      "// JS:  angka.filter(n => n % 2 === 0);",
      "// PHP array_filter tanpa callback = hapus falsy values",
      "// JS filter selalu butuh callback"
    ],
    "description": "Array filter JavaScript + penjelasan + perbandingan PHP"
  }
}