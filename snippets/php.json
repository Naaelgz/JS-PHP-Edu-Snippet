{
  "PHP - Variabel Dasar": {
    "scope": "php",
    "prefix": "edu-var",
    "body": [
      "// ======================================",
      "// PHP - VARIABEL DASAR",
      "// ======================================",
      "$${1:nama} = \"${2:Andi}\";",
      "$${3:umur} = ${4:20};",
      "",
      "echo $${1:nama};",
      "echo $${3:umur};",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// variabel di PHP selalu diawali dengan $",
      "// tidak perlu deklarasi tipe data",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS menggunakan let/const tanpa simbol $",
      "// contoh: let nama = \"Andi\";" 
    ],
    "description": "Variabel dasar PHP + penjelasan + perbandingan JS"
  },
  "PHP - If Statement": {
    "scope": "php",
    "prefix": "edu-if",
    "body": [
      "// ======================================",
      "// PHP - IF STATEMENT",
      "// ======================================",
      "$${1:nilai} = ${2:80};",
      "",
      "if ($${1:nilai} > ${3:75}) {",
      "  echo \"${4:Lulus}\";",
      "} else {",
      "  echo \"${5:Tidak Lulus}\";",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// if digunakan untuk percabangan logika",
      "// kondisi harus bernilai true agar dijalankan",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// Sintaks sama, JS menggunakan console.log untuk output",
      "// JS lebih ketat pada type comparison"
    ],
    "description": "If statement PHP + penjelasan + perbandingan JS"
  },
  "PHP - Loop For": {
    "scope": "php",
    "prefix": "edu-loop-for",
    "body": [
      "// ======================================",
      "// PHP - LOOP FOR",
      "// ======================================",
      "for ($${1:i} = ${2:0}; $${1:i} < ${3:3}; $${1:i}++) {",
      "  echo $${1:i};",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// for digunakan untuk perulangan dengan batas tertentu",
      "// terdiri dari inisialisasi, kondisi, increment",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS menggunakan let i dan console.log",
      "// contoh: for (let i = 0; i < 3; i++) { console.log(i); }"
    ],
    "description": "Loop for PHP + penjelasan + perbandingan JS"
  },
  "PHP - Array Dasar": {
    "scope": "php",
    "prefix": "edu-array",
    "body": [
      "// ======================================",
      "// PHP - ARRAY DASAR",
      "// ======================================",
      "$${1:buah} = [\"${2:apel}\", \"${3:jeruk}\", \"${4:mangga}\"];",
      "",
      "echo $${1:buah}[0]; // ${2:apel}",
      "",
      "// menambahkan data",
      "array_push($${1:buah}, \"${5:pisang}\");",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// array menyimpan banyak data",
      "// index dimulai dari 0",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS juga menggunakan [], tapi tanpa $",
      "// JS menggunakan .push() bukan array_push()"
    ],
    "description": "Array dasar PHP + penjelasan + perbandingan JS"
  },
  "PHP - Function Dasar": {
    "scope": "php",
    "prefix": "edu-func",
    "body": [
      "// ======================================",
      "// PHP - FUNCTION DASAR",
      "// ======================================",
      "function ${1:sapa}($${2:nama}) {",
      "  return \"Halo \" . $${2:nama};",
      "}",
      "",
      "echo ${1:sapa}(\"${3:Andi}\");",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// function untuk membuat kode yang bisa dipanggil ulang",
      "// parameter adalah input fungsi",
      "// return mengembalikan nilai",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS juga menggunakan function, tapi variabel tanpa $",
      "// JS menggunakan + untuk string concatenation"
    ],
    "description": "Function dasar PHP + penjelasan + perbandingan JS"
  },
  "PHP - Operator Aritmatika": {
    "scope": "php",
    "prefix": "edu-operator-arit",
    "body": [
      "// ======================================",
      "// PHP - OPERATOR ARITMATIKA",
      "// ======================================",
      "$${1:a} = ${2:10};",
      "$${3:b} = ${4:5};",
      "",
      "echo $${1:a} + $${3:b}; // penjumlahan",
      "echo $${1:a} - $${3:b}; // pengurangan",
      "echo $${1:a} * $${3:b}; // perkalian",
      "echo $${1:a} / $${3:b}; // pembagian",
      "echo $${1:a} % $${3:b}; // modulus",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// operator aritmatika digunakan untuk operasi matematika",
      "// % menghasilkan sisa bagi",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// operator sama persis dengan JS",
      "// perbedaan hanya pada penulisan variabel ($a, $b)"
      
    ],
    "description": "Operator aritmatika PHP + penjelasan + perbandingan JS"
  },
  "PHP - Operator Perbandingan": {
    "scope": "php",
    "prefix": "edu-operator-banding",
    "body": [
      "// ======================================",
      "// PHP - OPERATOR PERBANDINGAN",
      "// ======================================",
      "$${1:a} = ${2:10};",
      "$${3:b} = \"${4:10}\";",
      "",
      "var_dump($${1:a} == $${3:b});  // true (loose)",
      "var_dump($${1:a} === $${3:b}); // false (strict)",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// == membandingkan nilai saja (type juggling)",
      "// === membandingkan nilai dan tipe data",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS juga memiliki == dan ===",
      "// PHP lebih rentan type juggling dibanding JS"
      
    ],
    "description": "Operator perbandingan PHP + penjelasan + perbandingan JS"
  },
  "PHP - Operator Logika": {
    "scope": "php",
    "prefix": "edu-operator-logika",
    "body": [
      "// ======================================",
      "// PHP - OPERATOR LOGIKA",
      "// ======================================",
      "$${1:umur} = ${2:20};",
      "$${3:punyaKTP} = ${4:true};",
      "",
      "var_dump($${1:umur} > 17 && $${3:punyaKTP}); // AND",
      "var_dump($${1:umur} < 17 || $${3:punyaKTP}); // OR",
      "var_dump(!$${3:punyaKTP});                    // NOT",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// && = dan (kedua kondisi harus true)",
      "// || = atau (salah satu kondisi cukup true)",
      "// ! = negasi (membalik nilai boolean)",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// operator logika sama persis dengan JS",
      "// perbedaan hanya pada penulisan variabel"
      
    ],
    "description": "Operator logika PHP + penjelasan + perbandingan JS"
  },
  "PHP - Switch Case": {
    "scope": "php",
    "prefix": "edu-switch",
    "body": [
      "// ======================================",
      "// PHP - SWITCH CASE",
      "// ======================================",
      "$${1:hari} = \"${2:Senin}\";",
      "",
      "switch ($${1:hari}) {",
      "  case \"${3:Senin}\":",
      "    echo \"${4:Hari kerja}\";",
      "    break;",
      "  case \"${5:Minggu}\":",
      "    echo \"${6:Hari libur}\";",
      "    break;",
      "  default:",
      "    echo \"${7:Hari biasa}\";",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// switch digunakan untuk banyak kondisi",
      "// break mencegah eksekusi ke case berikutnya",
      "// default dijalankan jika tidak ada case yang cocok",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// struktur switch PHP dan JS hampir identik",
      "// perbedaan hanya pada penulisan variabel ($hari)"
      
    ],
    "description": "Switch case PHP + penjelasan + perbandingan JS"
  },
  "PHP - While Loop": {
    "scope": "php",
    "prefix": "edu-while",
    "body": [
      "// ======================================",
      "// PHP - WHILE LOOP",
      "// ======================================",
      "$${1:i} = ${2:0};",
      "",
      "while ($${1:i} < ${3:3}) {",
      "  echo $${1:i};",
      "  $${1:i}++;",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// while berjalan selama kondisi true",
      "// cocok untuk kondisi yang belum pasti jumlah perulangannya",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS memiliki sintaks while yang sama",
      "// perbedaan pada variabel ($i) dan output (echo vs console.log)"
      
    ],
    "description": "While loop PHP + penjelasan + perbandingan JS"
  },
  "PHP - Do While": {
    "scope": "php",
    "prefix": "edu-do-while",
    "body": [
      "// ======================================",
      "// PHP - DO WHILE",
      "// ======================================",
      "$${1:i} = ${2:0};",
      "",
      "do {",
      "  echo $${1:i};",
      "  $${1:i}++;",
      "} while ($${1:i} < ${3:3});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// do while dijalankan minimal 1 kali",
      "// kondisi dicek setelah eksekusi pertama",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// struktur do while PHP dan JS identik",
      "// perbedaan hanya pada sintaks variabel"
      
    ],
    "description": "Do while PHP + penjelasan + perbandingan JS"
  },
  "PHP - Break Continue": {
    "scope": "php",
    "prefix": "edu-break-continue",
    "body": [
      "// ======================================",
      "// PHP - BREAK & CONTINUE",
      "// ======================================",
      "for ($${1:i} = 0; $${1:i} < ${2:5}; $${1:i}++) {",
      "  if ($${1:i} === ${3:2}) continue; // skip angka ${3:2}",
      "  if ($${1:i} === ${4:4}) break;    // berhenti di ${4:4}",
      "  echo $${1:i};",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// continue: melewati iterasi tertentu",
      "// break: menghentikan loop sepenuhnya",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// konsep dan penggunaan identik dengan JS",
      "// PHP juga mendukung break 2; untuk keluar dari nested loop",
      "// JS menggunakan break; untuk keluar dari loop biasa"
    ],
    "description": "Break & continue PHP + penjelasan + perbandingan JS"
  },
  "PHP - Associative Array": {
    "scope": "php",
    "prefix": "edu-object",
    "body": [
      "// ======================================",
      "// PHP - ASSOCIATIVE ARRAY",
      "// ======================================",
      "$${1:user} = [",
      "  \"${2:nama}\" => \"${3:Andi}\",",
      "  \"${4:umur}\" => ${5:20}",
      "];",
      "",
      "echo $${1:user}[\"${2:nama}\"];",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// associative array menggunakan pasangan key => value",
      "// diakses menggunakan key-nya, bukan index angka",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS menggunakan object: { nama: \"Andi\", umur: 20 }",
      "// diakses dengan user.nama atau user[\"nama\"]",
      "// PHP menggunakan array asosiatif dengan key string"
    ],
    "description": "Associative array PHP + penjelasan + perbandingan JS"
  },
  "PHP - Foreach": {
    "scope": "php",
    "prefix": "edu-foreach",
    "body": [
      "// ======================================",
      "// PHP - FOREACH",
      "// ======================================",
      "$${1:buah} = [\"apel\", \"jeruk\", \"mangga\"];",
      "",
      "foreach ($${1:buah} as $${2:item}) {",
      "  echo $${2:item};",
      "}",
      "",
      "// dengan index:",
      "foreach ($${1:buah} as $${3:index} => $${2:item}) {",
      "  echo $${3:index} . \": \" . $${2:item};",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// foreach khusus untuk iterasi array",
      "// lebih simpel dibanding for biasa",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS menggunakan .forEach() sebagai method array",
      "// PHP foreach adalah struktur bahasa, bukan method"
      
    ],
    "description": "Foreach PHP + penjelasan + perbandingan JS"
  },
  "PHP - Tipe Data": {
    "scope": "php",
    "prefix": "edu-datatype",
    "body": [
      "// ======================================",
      "// PHP - TIPE DATA",
      "// ======================================",
      "$${1:angka} = ${2:10};         // integer",
      "$${3:desimal} = ${4:3.14};     // float",
      "$${5:teks} = \"${6:Halo}\";    // string",
      "$${7:benar} = ${8:true};       // boolean",
      "$${9:kosong} = null;           // null",
      "",
      "echo gettype($${1:angka});",
      "echo gettype($${5:teks});",
      "var_dump($${7:benar});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// PHP memiliki tipe data dinamis",
      "// gettype() untuk cek tipe, var_dump() untuk detail lebih",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS juga dynamic typing",
      "// JS menggunakan typeof, PHP menggunakan gettype()",
      "// JS memiliki undefined, PHP menggunakan null"

    ],
    "description": "Tipe data PHP + penjelasan + perbandingan JS"
  },
  "PHP - Function Return": {
    "scope": "php",
    "prefix": "edu-func-return",
    "body": [
      "// ======================================",
      "// PHP - FUNCTION RETURN",
      "// ======================================",
      "function ${1:tambah}($${2:a}, $${3:b}) {",
      "  return $${2:a} + $${3:b};",
      "}",
      "",
      "$${4:hasil} = ${1:tambah}(${5:5}, ${6:3});",
      "echo $${4:hasil};",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// parameter = input fungsi",
      "// return = nilai yang dikembalikan ke pemanggil",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// konsep return identik dengan JS",
      "// perbedaan hanya pada penulisan variabel ($a, $b)",
      "// JS: function tambah(a, b) { return a + b; }",
      "// PHP: function tambah($a, $b) { return $a + $b; }"
    ],
    "description": "Function return PHP + penjelasan + perbandingan JS"
  },
  "PHP - Akses Array": {
    "scope": "php",
    "prefix": "edu-array-access",
    "body": [
      "// ======================================",
      "// PHP - AKSES ARRAY",
      "// ======================================",
      "$${1:buah} = [\"apel\", \"jeruk\", \"mangga\"];",
      "",
      "echo $${1:buah}[${2:1}]; // jeruk",
      "",
      "// mengubah nilai",
      "$${1:buah}[${3:0}] = \"${4:pisang}\";",
      "print_r($${1:buah});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// array diakses menggunakan index (dimulai dari 0)",
      "// nilai array bisa diubah langsung",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS juga menggunakan index: buah[0]",
      "// JS menggunakan console.log, PHP menggunakan print_r",
      "// JS array bisa diubah langsung seperti PHP"

    ],
    "description": "Akses array PHP + penjelasan + perbandingan JS"
  },
  "PHP - Push Pop Array": {
    "scope": "php",
    "prefix": "edu-array-pushpop",
    "body": [
      "// ======================================",
      "// PHP - PUSH & POP ARRAY",
      "// ======================================",
      "$${1:angka} = [${2:1}, ${3:2}, ${4:3}];",
      "",
      "array_push($${1:angka}, ${5:4}); // tambah di akhir",
      "print_r($${1:angka});",
      "",
      "array_pop($${1:angka}); // hapus dari akhir",
      "print_r($${1:angka});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// array_push() menambah elemen di akhir",
      "// array_pop() menghapus elemen terakhir",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS menggunakan method: .push() dan .pop()",
      "// PHP menggunakan fungsi: array_push() dan array_pop()",
      "// konsepnya sama, hanya sintaks yang berbeda"
    ],
    "description": "Push & pop array PHP + penjelasan + perbandingan JS"
  },
  "PHP - Arrow Function": {
    "scope": "php",
    "prefix": "edu-arrow",
    "body": [
      "// ======================================",
      "// PHP - ARROW FUNCTION (fn)",
      "// ======================================",
      "$${1:tambah} = fn($${2:a}, $${3:b}) => $${2:a} + $${3:b};",
      "",
      "echo $${1:tambah}(${4:2}, ${5:3}); // output: 5",
      "",
      "// contoh dengan variabel dari luar (auto-capture):",
      "$${6:faktor} = ${7:2};",
      "$${8:kali} = fn($${9:x}) => $${9:x} * $${6:faktor};",
      "echo $${8:kali}(${10:5}); // output: 10",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// arrow function PHP menggunakan kata kunci fn",
      "// tersedia sejak PHP 7.4",
      "// otomatis menangkap variabel dari scope luar",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JS: const tambah = (a, b) => a + b;",
      "// PHP: $tambah = fn($a, $b) => $a + $b;",
      "// konsep sama, JS pakai => tanpa fn, PHP pakai fn =>",
      "// JS menangkap this secara otomatis, PHP menangkap variabel luar"

    ],
    "description": "Arrow function PHP (fn) + penjelasan + perbandingan JS"
  },
  "PHP - Array Map": {
    "scope": "php",
    "prefix": "edu-map",
    "body": [
      "// ======================================",
      "// PHP - ARRAY MAP",
      "// ======================================",
      "$${1:angka} = [${2:1}, ${3:2}, ${4:3}, ${5:4}, ${6:5}];",
      "",
      "// 1. Map dasar: transformasi setiap elemen",
      "$${7:dikali2} = array_map(fn($${8:n}) => $${8:n} * ${9:2}, $${1:angka});",
      "print_r($${7:dikali2}); // [2, 4, 6, 8, 10]",
      "",
      "// 2. Map dengan array of object/array",
      "$${10:users} = [",
      "  ['${11:nama}' => '${12:Andi}', '${13:umur}' => ${14:20}],",
      "  ['${11:nama}' => '${15:Budi}', '${13:umur}' => ${16:25}]",
      "];",
      "",
      "$${17:namaList} = array_map(fn($${18:u}) => $${18:u}['${11:nama}'], $${10:users});",
      "print_r($${17:namaList}); // ['Andi', 'Budi']",
      "",
      "// 3. Map multiple arrays sekaligus",
      "$${19:a} = [${20:1}, ${21:2}, ${22:3}];",
      "$${23:b} = [${24:10}, ${25:20}, ${26:30}];",
      "$${27:hasil} = array_map(fn($${28:x}, $${29:y}) => $${28:x} + $${29:y}, $${19:a}, $${23:b});",
      "print_r($${27:hasil}); // [11, 22, 33]",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// array_map() = terapkan fungsi ke setiap elemen",
      "// Tidak mengubah array asli",
      "// Parameter: callback dulu, array belakang",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// PHP: array_map(fn($n) => $n * 2, $angka);",
      "// JS:  angka.map(n => n * 2);",
      "// Bedanya: PHP fungsi dulu, array belakang",
      "// JS: method langsung di array"
    ],
    "description": "Array map PHP + penjelasan + perbandingan JS"
  },
  "PHP - Array Filter": {
    "scope": "php",
    "prefix": "edu-filter",
    "body": [
      "// ======================================",
      "// PHP - ARRAY FILTER",
      "// ======================================",
      "$${1:angka} = [${2:1}, ${3:2}, ${4:3}, ${5:4}, ${6:5}, ${7:6}];",
      "",
      "// 1. Filter dasar: ambil yang genap",
      "$${8:genap} = array_filter($${1:angka}, fn($${9:n}) => $${9:n} % 2 === 0);",
      "print_r($${8:genap}); // [2, 4, 6]",
      "",
      "// 2. Filter dengan associative array",
      "$${10:users} = [",
      "  ['${11:nama}' => '${12:Andi}', '${13:umur}' => ${14:17}],",
