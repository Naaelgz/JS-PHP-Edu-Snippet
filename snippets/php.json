      "  ['${11:nama}' => '${17:Citra}', '${13:umur}' => ${18:15}]",
      "];",
      "",
      "$${19:dewasa} = array_filter($${10:users}, fn($${20:u}) => $${20:u}['${13:umur}'] >= ${21:18});",
      "print_r($${19:dewasa});",
      "",
      "// 3. Filter tanpa callback (hapus falsy values)",
