{
  "Edu PHP Class Basic (OOP)": {
    "scope": "php",
    "prefix": "edu-php-class",
    "body": [
      "// =========================================",
      "// PHP OOP - CLASS DASAR",
      "// =========================================",
      "",
      "class ${1:User} {",
      "  // Property (variabel dalam class)",
      "  public $${2:nama};",
      "",
      "  // Method (function dalam class)",
      "  public function ${3:sapa}() {",
      "    return '${4:Halo, }' . $this->${2:nama};",
      "  }",
      "}",
      "",
      "// Membuat object",
      "$${5:user1} = new ${1:User}();",
      "$${5:user1}->${2:nama} = '${6:Budi}';",
      "",
      "echo $${5:user1}->${3:sapa}();",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Lupa pakai $this-> untuk akses property",
      "// Salah tulis new (huruf kecil wajib)",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Gunakan camelCase untuk method",
      "// Gunakan PascalCase untuk nama class",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS ES6: class User { constructor() {} method() {} }",
      "// PHP: class User { public $prop; public function method() {} }"
    ],
    "description": "PHP OOP Class dasar dengan penjelasan + tab stops"
  },
  "Edu PHP Constructor (OOP)": {
    "scope": "php",
    "prefix": "edu-php-construct",
    "body": [
      "// =========================================",
      "// PHP OOP - CONSTRUCTOR",
      "// =========================================",
      "",
      "class ${1:User} {",
      "  public $${2:nama};",
      "  public $${3:email};",
      "",
      "  // Constructor otomatis dipanggil saat object dibuat",
      "  public function __construct($${4:nama}, $${5:email}) {",
      "    $this->${2:nama} = $${4:nama};",
      "    $this->${3:email} = $${5:email};",
      "  }",
      "",
      "  public function ${6:info}() {",
      "    return $this->${2:nama} . ' - ' . $this->${3:email};",
      "  }",
      "}",
      "",
      "$${7:user} = new ${1:User}('${8:Andi}', '${9:andi@example.com}');",
      "echo $${7:user}->${6:info}();",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Salah tulis __construct (harus double underscore)",
      "// Tidak assign ke $this->",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Gunakan constructor untuk inisialisasi data awal",
      "// Hindari logic berat di constructor",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS: constructor(nama, email) { this.nama = nama; }",
      "// PHP: public function __construct($nama, $email) { $this->nama = $nama; }"
    ],
    "description": "PHP constructor dengan best practice + tab stops"
  },
  "Edu PHP Encapsulation (OOP)": {
    "scope": "php",
    "prefix": "edu-php-encap",
    "body": [
      "// =========================================",
      "// PHP OOP - ENCAPSULATION",
      "// =========================================",
      "",
      "class ${1:User} {",
      "  private $${2:nama};",
      "  private $${3:umur};",
      "",
      "  public function set${4:Nama}($${5:nama}) {",
      "    if (empty($${5:nama})) {",
      "      throw new Exception('${6:Nama tidak boleh kosong}');",
      "    }",
      "    $this->${2:nama} = $${5:nama};",
      "  }",
      "",
      "  public function get${4:Nama}() {",
      "    return $this->${2:nama};",
      "  }",
      "",
      "  public function set${7:Umur}($${8:umur}) {",
      "    if ($${8:umur} < 0) {",
      "      throw new Exception('${9:Umur tidak valid}');",
      "    }",
      "    $this->${3:umur} = $${8:umur};",
      "  }",
      "",
      "  public function get${7:Umur}() {",
      "    return $this->${3:umur};",
      "  }",
      "}",
      "",
      "$${10:user} = new ${1:User}();",
      "$${10:user}->set${4:Nama}('${11:Budi}');",
      "$${10:user}->set${7:Umur}(${12:25});",
      "echo $${10:user}->get${4:Nama}();",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Akses property private langsung dari luar → ERROR",
      "// Lupa validasi di setter",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Gunakan private untuk keamanan data",
      "// Tambahkan validasi di setter",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS ES2022: #nama (private field)",
      "// PHP: private $nama (lebih lama, lebih stabil)"
    ],
    "description": "Encapsulation PHP dengan getter setter + tab stops"
  },
  "Edu PHP Inheritance (OOP)": {
    "scope": "php",
    "prefix": "edu-php-inherit",
    "body": [
      "// =========================================",
      "// PHP OOP - INHERITANCE",
      "// =========================================",
      "",
      "class ${1:User} {",
      "  public $${2:nama};",
      "",
      "  public function __construct($${3:nama}) {",
      "    $this->${2:nama} = $${3:nama};",
      "  }",
      "",
      "  public function ${4:role}() {",
      "    return '${5:User biasa}';",
      "  }",
      "",
      "  public function ${6:info}() {",
      "    return $this->${2:nama} . ' adalah ' . $this->${4:role}();",
      "  }",
      "}",
      "",
      "// ${7:Admin} mewarisi ${1:User}",
      "class ${7:Admin} extends ${1:User} {",
      "  public function ${4:role}() {",
      "    return '${8:Administrator}'; // Override method parent",
      "  }",
      "",
      "  public function ${9:hapusUser}($${10:id}) {",
      "    return '${11:User #}' . $${10:id} . '${12: dihapus}';",
      "  }",
      "}",
      "",
      "$${13:user} = new ${1:User}('${14:Budi}');",
      "$${15:admin} = new ${7:Admin}('${16:Andi}');",
      "",
      "echo $${13:user}->${6:info}();  // Budi adalah User biasa",
      "echo $${15:admin}->${6:info}(); // Andi adalah Administrator",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Lupa keyword extends",
      "// Tidak panggil parent::__construct() jika parent punya constructor",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Gunakan parent::method() untuk akses method parent",
      "// Hindari inheritance terlalu dalam (max 3 level)",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS: class Admin extends User { constructor() { super(); } }",
      "// PHP: class Admin extends User { public function __construct() { parent::__construct(); } }"
    ],
    "description": "Inheritance PHP dengan contoh sederhana + tab stops"
  },
  "Edu PHP Polymorphism (OOP)": {
    "scope": "php",
    "prefix": "edu-php-poly",
    "body": [
      "// =========================================",
      "// PHP OOP - POLYMORPHISM",
      "// =========================================",
      "",
      "class ${1:User} {",
      "  public $${2:nama};",
      "",
      "  public function __construct($${3:nama}) {",
      "    $this->${2:nama} = $${3:nama};",
      "  }",
      "",
      "  public function ${4:akses}() {",
      "    return '${5:Akses terbatas}';",
      "  }",
      "}",
      "",
      "class ${6:Admin} extends ${1:User} {",
      "  public function ${4:akses}() {",
      "    return '${7:Akses penuh}';",
      "  }",
      "}",
      "",
      "class ${8:Moderator} extends ${1:User} {",
      "  public function ${4:akses}() {",
      "    return '${9:Akses moderasi}';",
      "  }",
      "}",
      "",
      "// Satu fungsi, banyak bentuk perilaku",
      "function ${10:tampilAkses}(${1:User} $${11:user}) {",
      "  echo $${11:user}->${2:nama} . ': ' . $${11:user}->${4:akses}() . \"\\n\";",
      "}",
      "",
      "${10:tampilAkses}(new ${1:User}('${12:Budi}'));",
      "${10:tampilAkses}(new ${6:Admin}('${13:Andi}'));",
      "${10:tampilAkses}(new ${8:Moderator}('${14:Citra}'));",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Tidak pakai type hinting → kehilangan manfaat polymorphism",
      "// Override method tanpa memahami kontrak parent",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Gunakan type hinting di parameter fungsi",
      "// Pertimbangkan Interface untuk kontrak yang lebih ketat",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS tidak punya type hinting native",
      "// JS pakai duck typing: if method ada, panggil saja",
      "// TypeScript punya interface untuk hal serupa"
    ],
    "description": "Polymorphism PHP dengan contoh praktis + tab stops"
  },
  "Edu PHP Interface (OOP)": {
    "scope": "php",
    "prefix": "edu-php-interface",
    "body": [
      "// =========================================",
      "// PHP OOP - INTERFACE",
      "// =========================================",
      "",
      "// Interface = kontrak yang WAJIB diimplementasi",
      "interface ${1:Printable} {",
      "  public function ${2:print}(): ${3:string};",
      "  public function ${4:getFormat}(): ${5:string};",
      "}",
      "",
      "interface ${6:Exportable} {",
      "  public function ${7:export}(${8:string} $${9:format}): ${10:bool};",
      "}",
      "",
      "// Class WAJIB implement semua method interface",
      "class ${11:Document} implements ${1:Printable}, ${6:Exportable} {",
      "  private ${12:string} $${13:content};",
      "",
      "  public function __construct(${12:string} $${14:content}) {",
      "    $this->${13:content} = $${14:content};",
      "  }",
      "",
      "  public function ${2:print}(): ${3:string} {",
      "    return $this->${13:content};",
      "  }",
      "",
      "  public function ${4:getFormat}(): ${5:string} {",
      "    return '${15:txt}';",
      "  }",
      "",
      "  public function ${7:export}(${8:string} $${9:format}): ${10:bool} {",
      "    echo \"${16:Exporting as }$${9:format}\\n\";",
      "    return true;",
      "  }",
      "}",
      "",
      "$${17:doc} = new ${11:Document}('${18:Isi dokumen}');",
      "echo $${17:doc}->${2:print}();",
      "$${17:doc}->${7:export}('${19:pdf}');",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Tidak implement semua method interface → Fatal Error",
      "// Interface tidak bisa punya property",
      "// Interface tidak bisa punya method dengan body",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Interface untuk mendefinisikan kontrak",
      "// Satu class bisa implement banyak interface",
      "// Nama interface biasanya kata sifat: -able, -ible",
      "",
      "// =========================================",
      "// INTERFACE vs ABSTRACT vs TRAIT",
      "// =========================================",
      "// Interface: kontrak tanpa implementasi",
      "// Abstract: blueprint dengan sebagian implementasi",
      "// Trait: reusable method (bukan inheritance)",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS tidak punya interface native",
      "// TypeScript: interface Printable { print(): string; }",
      "// JS pakai duck typing sebagai gantinya"
    ],
    "description": "Interface PHP + penjelasan lengkap"
  },
  "Edu PHP Abstract Class (OOP)": {
    "scope": "php",
    "prefix": "edu-php-abstract",
    "body": [
      "// =========================================",
      "// PHP OOP - ABSTRACT CLASS",
      "// =========================================",
      "",
      "// Abstract class = blueprint yang tidak bisa di-instantiate",
      "abstract class ${1:Shape} {",
      "  protected ${2:string} $${3:warna};",
      "",
      "  public function __construct(${2:string} $${4:warna}) {",
      "    $this->${3:warna} = $${4:warna};",
      "  }",
      "",
      "  // Method abstrak: WAJIB diimplementasi child class",
      "  abstract public function ${5:hitungLuas}(): ${6:float};",
      "  abstract public function ${7:hitungKeliling}(): ${8:float};",
      "",
      "  // Method konkrit: bisa langsung dipakai",
      "  public function ${9:info}(): ${10:string} {",
      "    return \"${11:Warna}: {$this->${3:warna}}, Luas: {$this->${5:hitungLuas}()}\";",
      "  }",
      "}",
      "",
      "class ${12:Lingkaran} extends ${1:Shape} {",
      "  private ${13:float} $${14:radius};",
      "",
      "  public function __construct(${13:float} $${15:radius}, ${2:string} $${4:warna}) {",
      "    parent::__construct($${4:warna});",
      "    $this->${14:radius} = $${15:radius};",
      "  }",
      "",
      "  public function ${5:hitungLuas}(): ${6:float} {",
      "    return M_PI * $this->${14:radius} ** 2;",
      "  }",
      "",
      "  public function ${7:hitungKeliling}(): ${8:float} {",
      "    return 2 * M_PI * $this->${14:radius};",
      "  }",
      "}",
      "",
      "class ${16:Persegi} extends ${1:Shape} {",
      "  private ${13:float} $${17:sisi};",
      "",
      "  public function __construct(${13:float} $${18:sisi}, ${2:string} $${4:warna}) {",
      "    parent::__construct($${4:warna});",
      "    $this->${17:sisi} = $${18:sisi};",
      "  }",
      "",
      "  public function ${5:hitungLuas}(): ${6:float} {",
      "    return $this->${17:sisi} ** 2;",
      "  }",
      "",
      "  public function ${7:hitungKeliling}(): ${8:float} {",
      "    return 4 * $this->${17:sisi};",
      "  }",
      "}",
      "",
      "$${19:c} = new ${12:Lingkaran}(${20:5.0}, '${21:merah}');",
      "$${22:p} = new ${16:Persegi}(${23:4.0}, '${24:biru}');",
      "",
      "echo $${19:c}->${9:info}();",
      "echo $${22:p}->${9:info}();",
      "",
      "// =========================================",
      "// ⚠️ COMMON MISTAKE",
      "// =========================================",
      "// Mencoba new AbstractClass() → Fatal Error",
      "// Lupa implement semua abstract method di child class",
      "",
      "// =========================================",
      "// 💡 BEST PRACTICE",
      "// =========================================",
      "// Gunakan abstract saat ada method yang implementasinya",
      "// berbeda tiap subclass, tapi ada logic bersama",
      "",
      "// =========================================",
      "// ABSTRACT vs INTERFACE",
      "// =========================================",
      "// Abstract: ada implementasi sebagian (extends, 1 parent)",
      "// Interface: tidak ada implementasi (implements, bisa banyak)",
      "",
      "// =========================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// =========================================",
      "// JS tidak punya abstract class native",
      "// Workaround: throw Error di constructor atau method",
      "// TypeScript: abstract class Shape { abstract hitungLuas(): number; }"
    ],
    "description": "Abstract class PHP + penjelasan lengkap"
  },
  "PHP Advanced - Namespace Basic": {
    "scope": "php",
    "prefix": "edu-namespace",
    "body": [
      "// ======================================",
      "// PHP - NAMESPACE DASAR",
      "// ======================================",
      "namespace ${1:App\\Models};",
      "",
      "class ${2:User} {",
      "  public $${3:nama};",
      "",
      "  public function __construct($${4:nama}) {",
      "    $this->${3:nama} = $${4:nama};",
      "  }",
      "}",
      "",
      "// Di file lain:",
      "// use App\\Models\\User;",
      "// $user = new User('Andi');",
      "",
      "// Atau tanpa use:",
      "// $user = new \\App\\Models\\User('Andi');",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Namespace mengorganisir kode seperti folder",
      "// Mencegah konflik nama class yang sama",
      "// Backslash (\\) sebagai separator",
      "// Namespace harus di baris pertama (setelah <?php)",
      "",
      "// ======================================",
      "// KONVENSI",
      "// ======================================",
      "// PSR-4: namespace mengikuti struktur folder",
      "// App\\Models\\User -> app/Models/User.php",
      "// Gunakan PascalCase untuk nama namespace",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JavaScript punya ES6 modules:",
      "// export class User { }",
      "// import { User } from './User.js';",
      "// Konsepnya mirip tapi sintaks berbeda"
    ],
    "description": "Namespace dasar PHP + penjelasan"
  },
  "PHP Advanced - Use Statement": {
    "scope": "php",
    "prefix": "edu-use",
    "body": [
      "// ======================================",
      "// PHP - USE STATEMENT",
      "// ======================================",
      "",
      "// 1. Import single class",
      "use ${1:App\\Models\\User};",
      "",
      "// 2. Import dengan alias",
      "use ${2:App\\Services\\UserService} as ${3:US};",
      "",
      "// 3. Import multiple dari namespace sama",
      "use ${4:App\\Models\\{${5:User}, ${6:Product}, ${7:Order}}};",
      "",
      "// 4. Import function (PHP 5.6+)",
      "use function ${8:App\\Helpers\\formatDate};",
      "",
      "// 5. Import constant",
      "use const ${9:App\\Config\\DB_HOST};",
      "",
      "// Penggunaan:",
      "$${10:user} = new ${5:User}();",
      "$${11:service} = new ${3:US}();",
      "$${12:tanggal} = ${8:formatDate}('${13:2024-01-01}');",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// use statement meng-import class/function/constant",
      "// Harus di atas file, setelah namespace",
      "// Tidak wajib, tapi membuat kode lebih singkat",
      "",
      "// ======================================",
      "// TANPA USE",
      "// ======================================",
      "// $user = new \\App\\Models\\User(); // fully qualified name",
      "",
      "// ======================================",
      "// BEST PRACTICE",
      "// ======================================",
      "// - Group use untuk class dari namespace sama",
      "// - Gunakan alias jika ada konflik nama",
      "// - Sort alfabetis untuk readability",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JavaScript ES6:",
      "// import { User, Product } from './models';",
      "// import UserService as US from './services';",
      "// Konsepnya sama, sintaks sedikit berbeda"
    ],
    "description": "Use statement PHP + penjelasan lengkap"
  },
  "PHP Advanced - Try Catch Basic": {
    "scope": "php",
    "prefix": "edu-try-catch",
    "body": [
      "// ======================================",
      "// PHP - TRY CATCH ERROR HANDLING",
      "// ======================================",
      "try {",
      "  // Kode yang mungkin error",
      "  $${1:file} = fopen('${2:data.txt}', '${3:r}');",
      "",
      "  if (!$${1:file}) {",
      "    throw new Exception('${4:File tidak ditemukan}');",
      "  }",
      "",
      "  // Proses file...",
      "  $${5:content} = fread($${1:file}, filesize('${2:data.txt}'));",
      "  fclose($${1:file});",
      "",
      "  echo $${5:content};",
      "",
      "} catch (Exception $${6:e}) {",
      "  // Tangani error",
      "  echo \"${7:Error}: \" . $${6:e}->getMessage();",
      "",
      "} finally {",
      "  // Selalu dijalankan (opsional)",
      "  echo \"${8:\\nProses selesai}\";",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// try: kode yang mungkin error",
      "// catch: menangkap dan menangani error",
      "// throw: melempar error manual",
      "// finally: dijalankan apapun hasilnya (opsional)",
      "",
      "// ======================================",
      "// MULTIPLE CATCH (PHP 7.1+)",
      "// ======================================",
      "// try {",
      "//   // kode...",
      "// } catch (InvalidArgumentException $e) {",
      "//   // handle specific error",
      "// } catch (Exception $e) {",
      "//   // handle generic error",
      "// }",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JavaScript syntax identik:",
      "// try { } catch (error) { } finally { }",
      "// Tapi JS lebih sering pakai .catch() di Promise"
    ],
    "description": "Try-catch error handling PHP + penjelasan"
  },
  "PHP Advanced - Custom Exception": {
    "scope": "php",
    "prefix": "edu-custom-exception",
    "body": [
      "// ======================================",
      "// PHP - CUSTOM EXCEPTION CLASS",
      "// ======================================",
      "class ${1:ValidationException} extends Exception {",
      "  protected $${2:field};",
      "",
      "  public function __construct(",
      "    $${3:message},",
      "    $${2:field} = ${4:null},",
      "    $${5:code} = ${6:0}",
      "  ) {",
      "    parent::__construct($${3:message}, $${5:code});",
      "    $this->${2:field} = $${2:field};",
      "  }",
      "",
      "  public function getField() {",
      "    return $this->${2:field};",
      "  }",
      "",
      "  public function getFullMessage() {",
      "    return $this->${2:field}",
      "      ? \"{$this->${2:field}}: {$this->message}\"",
      "      : $this->message;",
      "  }",
      "}",
      "",
      "// Penggunaan:",
      "try {",
      "  $${7:email} = '${8:invalid-email}';",
      "",
      "  if (!filter_var($${7:email}, FILTER_VALIDATE_EMAIL)) {",
      "    throw new ${1:ValidationException}(",
      "      '${9:Format email tidak valid}',",
      "      '${10:email}'",
      "    );",
      "  }",
      "",
      "} catch (${1:ValidationException} $${11:e}) {",
      "  echo $${11:e}->getFullMessage();",
      "  // Output: \"email: Format email tidak valid\"",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Custom exception untuk error spesifik",
      "// Extends Exception untuk inherit method bawaan",
      "// Bisa tambah property & method custom",
      "",
      "// ======================================",
      "// BUILT-IN EXCEPTION CLASSES",
      "// ======================================",
      "// InvalidArgumentException",
      "// RuntimeException",
      "// LogicException",
      "// OutOfBoundsException",
      "",
      "// ======================================",
      "// BEST PRACTICE",
      "// ======================================",
      "// - Buat exception class untuk error domain-specific",
      "// - Gunakan built-in exception jika cocok",
      "// - Catch dari yang paling spesifik dulu"
    ],
    "description": "Custom exception class PHP + penjelasan"
  },
  "PHP Advanced - PDO Connection": {
    "scope": "php",
    "prefix": "edu-pdo-connect",
    "body": [
      "// ======================================",
      "// PHP - PDO DATABASE CONNECTION",
      "// ======================================",
      "try {",
      "  $${1:host} = '${2:localhost}';",
      "  $${3:dbname} = '${4:database_name}';",
      "  $${5:username} = '${6:root}';",
      "  $${7:password} = '${8:}';",
      "",
      "  // DSN (Data Source Name)",
      "  $${9:dsn} = \"mysql:host=$${1:host};dbname=$${3:dbname};charset=utf8mb4\";",
      "",
      "  // Options untuk keamanan & performa",
      "  $${10:options} = [",
      "    PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,",
      "    PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,",
      "    PDO::ATTR_EMULATE_PREPARES => false,",
      "  ];",
      "",
      "  // Buat koneksi",
      "  $${11:pdo} = new PDO($${9:dsn}, $${5:username}, $${7:password}, $${10:options});",
      "",
      "  echo \"${12:Koneksi berhasil!}\";",
      "",
      "} catch (PDOException $${13:e}) {",
      "  die(\"${14:Koneksi gagal}: \" . $${13:e}->getMessage());",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// PDO = PHP Data Objects (cara modern akses database)",
      "// Mendukung berbagai database: MySQL, PostgreSQL, SQLite",
      "// ERRMODE_EXCEPTION: lempar exception jika error",
      "// FETCH_ASSOC: return hasil query sebagai array asosiatif",
      "",
      "// ======================================",
      "// BEST PRACTICE",
      "// ======================================",
      "// - Gunakan environment variables untuk credentials",
      "// - Jangan hardcode password di kode",
      "// - Set charset ke utf8mb4 untuk emoji support",
      "// - Selalu gunakan prepared statements"
    ],
    "description": "PDO database connection + penjelasan"
  },
  "PHP Advanced - PDO Query Select": {
    "scope": "php",
    "prefix": "edu-pdo-select",
    "body": [
      "// ======================================",
      "// PHP - PDO SELECT QUERY",
      "// ======================================",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Gunakan prepared statement untuk keamanan",
      "// Parameter binding mencegah SQL injection",
      "// fetchAll() ambil semua baris, fetch() ambil 1 baris",
      "",
      "",
      "// Prepared statement (RECOMMENDED)",
      "$${1:sql} = \"SELECT * FROM ${2:users} WHERE ${3:id} = :${4:id}\";",
      "$${5:stmt} = $${6:pdo}->prepare($${1:sql});",
      "$${5:stmt}->execute([':${4:id}' => $${7:1}]);",
      "$${8:user} = $${5:stmt}->fetch();",
      "",
      "// Multiple parameters",
      "$${9:sql2} = \"SELECT * FROM ${2:users} WHERE ${10:age} > :${11:min_age} AND ${12:city} = :${13:city}\";",
      "$${14:stmt2} = $${6:pdo}->prepare($${9:sql2});",
      "$${14:stmt2}->execute([",
      "  ':${11:min_age}' => ${15:18},",
      "  ':${13:city}' => '${16:Jakarta}'",
      "]);",
      "$${17:results} = $${14:stmt2}->fetchAll();",
      "",
      "// Loop hasil",
      "foreach ($${17:results} as $${18:row}) {",
      "  echo $${18:row}['${19:nama}'] . \"\\n\";",
      "}",
      "",
      "// ======================================",
      "// FETCH METHODS",
      "// ======================================",
      "// fetch()       - ambil 1 row",
      "// fetchAll()    - ambil semua row",
      "// fetchColumn() - ambil 1 kolom dari 1 row",
      "// rowCount()    - hitung jumlah row",
      "",
      "// ======================================",
      "// ⚠️ COMMON MISTAKE",
      "// ======================================",
      "// JANGAN: $sql = \"SELECT * FROM users WHERE id = $_GET[id]\";",
      "// Bisa diserang: ?id=1 OR 1=1",
      "// GUNAKAN prepared statement!"
    ],
    "description": "PDO SELECT query dengan prepared statement + penjelasan"
  },
  "PHP Advanced - PDO Insert": {
    "scope": "php",
    "prefix": "edu-pdo-insert",
    "body": [
      "// ======================================",
      "// PHP - PDO INSERT DATA",
      "// ======================================",
      "try {",
      "  $${1:sql} = \"",
      "    INSERT INTO ${2:users} (${3:nama}, ${4:email}, ${5:umur})",
      "    VALUES (:${6:nama}, :${7:email}, :${8:umur})",
      "  \";",
      "",
      "  $${9:stmt} = $${10:pdo}->prepare($${1:sql});",
      "  $${9:stmt}->execute([",
      "    ':${6:nama}' => '${11:Andi}',",
      "    ':${7:email}' => '${12:andi@example.com}',",
      "    ':${8:umur}' => ${13:20}",
      "  ]);",
      "",
      "  $${14:lastId} = $${10:pdo}->lastInsertId();",
      "  echo \"${15:Data berhasil disimpan dengan ID: }\" . $${14:lastId};",
      "",
      "} catch (PDOException $${16:e}) {",
      "  echo \"${17:Error}: \" . $${16:e}->getMessage();",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// INSERT menambahkan data baru ke tabel",
      "// lastInsertId() untuk ambil auto-increment ID",
      "// Gunakan prepared statement untuk keamanan",
      "",
      "// ======================================",
      "// BEST PRACTICE",
      "// ======================================",
      "// - Validasi data sebelum insert",
      "// - Gunakan transaction untuk multiple insert",
      "// - Handle duplicate entry error"
    ],
    "description": "PDO INSERT dengan prepared statement + penjelasan"
  },
  "PHP Advanced - PDO Update Delete": {
    "scope": "php",
    "prefix": "edu-pdo-update",
    "body": [
      "// ======================================",
      "// PHP - PDO UPDATE & DELETE",
      "// ======================================",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// UPDATE mengubah data yang sudah ada",
      "// DELETE menghapus data secara permanen",
      "// rowCount() mengembalikan jumlah baris yang terpengaruh",
      "",
      "",
      "// 1. UPDATE DATA",
      "try {",
      "  $${1:sql} = \"UPDATE ${2:users} SET ${3:nama} = :${4:nama}, ${5:email} = :${6:email} WHERE ${7:id} = :${8:id}\";",
      "",
      "  $${9:stmt} = $${10:pdo}->prepare($${1:sql});",
      "  $${9:stmt}->execute([",
      "    ':${4:nama}' => '${11:Andi Baru}',",
      "    ':${6:email}' => '${12:andi.baru@example.com}',",
      "    ':${8:id}' => ${13:1}",
      "  ]);",
      "",
      "  echo $${9:stmt}->rowCount() . ' baris diupdate';",
      "",
      "} catch (PDOException $${14:e}) {",
      "  echo \"Error: \" . $${14:e}->getMessage();",
      "}",
      "",
      "// 2. DELETE DATA",
      "try {",
      "  $${15:sql} = \"DELETE FROM ${2:users} WHERE ${7:id} = :${8:id}\";",
      "",
      "  $${16:stmt} = $${10:pdo}->prepare($${15:sql});",
      "  $${16:stmt}->execute([':${8:id}' => ${17:1}]);",
      "",
      "  echo $${16:stmt}->rowCount() . ' baris dihapus';",
      "",
      "} catch (PDOException $${18:e}) {",
      "  echo \"Error: \" . $${18:e}->getMessage();",
      "}",
      "",
      "// ======================================",
      "// ⚠️ COMMON MISTAKE",
      "// ======================================",
      "// DELETE FROM users; <- HAPUS SEMUA DATA!",
      "// SELALU gunakan WHERE!",
      "",
      "// ======================================",
      "// 💡 BEST PRACTICE",
      "// ======================================",
      "// UPDATE users SET deleted_at = NOW() WHERE id = 1;",
      "// Data tidak terhapus fisik, bisa di-restore"
    ],
    "description": "PDO UPDATE & DELETE dengan prepared statement"
  },
  "PHP Advanced - Trait Basic": {
    "scope": "php",
    "prefix": "edu-trait",
    "body": [
      "// ======================================",
      "// PHP - TRAIT DASAR",
      "// ======================================",
      "",
      "// 1. Definisi Trait",
      "trait ${1:Timestampable} {",
      "  protected $${2:createdAt};",
      "  protected $${3:updatedAt};",
      "",
      "  public function setCreatedAt() {",
      "    $this->${2:createdAt} = date('${4:Y-m-d H:i:s}');",
      "  }",
      "",
      "  public function setUpdatedAt() {",
      "    $this->${3:updatedAt} = date('${4:Y-m-d H:i:s}');",
      "  }",
      "",
      "  public function getTimestamps() {",
      "    return ['${5:created}' => $this->${2:createdAt}, '${6:updated}' => $this->${3:updatedAt}];",
      "  }",
      "}",
      "",
      "// 2. Gunakan Trait di Class",
      "class ${7:User} {",
      "  use ${1:Timestampable};",
      "",
      "  public $${8:nama};",
      "",
      "  public function __construct($${9:nama}) {",
      "    $this->${8:nama} = $${9:nama};",
      "    $this->setCreatedAt();",
      "  }",
      "}",
      "",
      "$${10:user} = new ${7:User}('${11:Andi}');",
      "$${10:user}->setUpdatedAt();",
      "print_r($${10:user}->getTimestamps());",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Trait = kumpulan method yang bisa dipakai ulang",
      "// Solusi untuk horizontal reuse",
      "// PHP tidak punya multiple inheritance → pakai Trait",
      "",
      "// ======================================",
      "// TRAIT vs CLASS vs INTERFACE",
      "// ======================================",
      "// Interface: kontrak (apa yang harus ada)",
      "// Abstract Class: blueprint (extends)",
      "// Trait: reusable code (use)",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN JAVASCRIPT",
      "// ======================================",
      "// JavaScript tidak punya trait built-in",
      "// Tapi bisa pakai mixin pattern:",
      "// Object.assign(MyClass.prototype, TimestampMixin);"
    ],
    "description": "Trait dasar PHP + penjelasan"
  },
  "PHP Advanced - Multiple Traits": {
    "scope": "php",
    "prefix": "edu-trait-multiple",
    "body": [
      "// ======================================",
      "// PHP - MULTIPLE TRAITS",
      "// ======================================",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Satu class bisa pakai lebih dari satu trait",
      "// Trait memungkinkan reuse kode tanpa inheritance",
      "// Berguna untuk fungsionalitas lintas class (logging, validasi, dll)",
      "",
      "",
      "trait ${1:Loggable} {",
      "  public function log($${2:message}) {",
      "    echo \"${3:[LOG] }\" . date('${4:H:i:s}') . \" - $${2:message}\\n\";",
      "  }",
      "}",
      "",
      "trait ${5:Validatable} {",
      "  public function validate($${6:data}) {",
      "    if (empty($${6:data})) {",
      "      throw new Exception('${7:Data tidak boleh kosong}');",
      "    }",
      "    return true;",
      "  }",
      "}",
      "",
      "class ${8:User} {",
      "  use ${1:Loggable}, ${5:Validatable};",
      "",
      "  public $${9:nama};",
      "",
      "  public function setNama($${10:nama}) {",
      "    $this->validate($${10:nama});",
      "    $this->${9:nama} = $${10:nama};",
      "    $this->log(\"Nama diset: $${10:nama}\");",
      "  }",
      "}",
      "",
      "$${11:user} = new ${8:User}();",
      "$${11:user}->setNama('${12:Andi}');",
      "",
      "// ======================================",
      "// CONFLICT RESOLUTION",
      "// ======================================",
      "// Jika dua trait punya method sama, gunakan insteadof & as:",
      "// use TraitA, TraitB {",
      "//   TraitA::hello insteadof TraitB;",
      "//   TraitB::hello as helloB;",
      "// }",
      "",
      "// ======================================",
      "// BEST PRACTICE",
      "// ======================================",
      "// - Hindari method dengan nama sama di berbagai trait",
      "// - Gunakan trait untuk cross-cutting concerns",
      "// - Jangan overuse trait (prefer composition)"
    ],
    "description": "Multiple traits & conflict resolution + penjelasan"
  },
  "PHP Advanced - PDO Transaction": {
    "scope": "php",
    "prefix": "edu-pdo-transaction",
    "body": [
      "// ======================================",
      "// PHP - PDO TRANSACTION",
      "// ======================================",
      "try {",
      "  $${1:pdo}->beginTransaction();",
      "",
      "  // Operasi 1",
      "  $${2:stmt1} = $${1:pdo}->prepare(\"INSERT INTO ${3:users} (${4:nama}, ${5:email}) VALUES (:${6:nama}, :${7:email})\");",
      "  $${2:stmt1}->execute([':${6:nama}' => '${8:Andi}', ':${7:email}' => '${9:andi@example.com}']);",
      "  $${10:userId} = $${1:pdo}->lastInsertId();",
      "",
      "  // Operasi 2 (bergantung pada operasi 1)",
      "  $${11:stmt2} = $${1:pdo}->prepare(\"INSERT INTO ${12:user_profiles} (${13:user_id}, ${14:bio}) VALUES (:${15:uid}, :${16:bio})\");",
      "  $${11:stmt2}->execute([':${15:uid}' => $${10:userId}, ':${16:bio}' => '${17:Mahasiswa informatika}']);",
      "",
      "  $${1:pdo}->commit();",
      "  echo \"${18:Transaksi berhasil!}\";",
      "",
      "} catch (Exception $${19:e}) {",
      "  $${1:pdo}->rollBack();",
      "  echo \"${20:Transaksi gagal: }\" . $${19:e}->getMessage();",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// Transaction: kelompok operasi all-or-nothing",
      "// beginTransaction() - mulai",
      "// commit()           - simpan semua perubahan",
      "// rollBack()         - batalkan semua jika ada error",
      "",
      "// ======================================",
      "// KAPAN PAKAI TRANSACTION",
      "// ======================================",
      "// - Transfer uang (debit & kredit bersamaan)",
      "// - Buat user + profile + permissions sekaligus",
      "// - Delete parent record + semua child records",
      "",
      "// ======================================",
      "// PERBANDINGAN KONSEP (ACID)",
      "// ======================================",
      "// A - Atomicity: semua atau tidak sama sekali",
      "// C - Consistency: data tetap valid",
      "// I - Isolation: transaction tidak saling ganggu",
      "// D - Durability: hasil transaction permanen"
    ],
    "description": "PDO transaction untuk multiple operations + penjelasan"
  }
}