{
  "JS - Variabel Dasar": {
    "scope": "javascript",
    "prefix": "edu-var",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - VARIABEL DASAR",
      "// ======================================",
      "let ${1:nama} = ${2:\"Andi\"}; // deklarasi variabel",
      "const ${3:umur} = ${4:20}; // konstanta (tidak bisa diubah)",
      "",
      "console.log(${1:nama});",
      "console.log(${3:umur});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// let digunakan untuk variabel yang bisa berubah",
      "// const digunakan untuk nilai tetap",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP menggunakan simbol $ untuk variabel",
      "// contoh: $nama = \"Andi\";",
      "// JS tidak menggunakan simbol khusus"
    ],
    "description": "Variabel dasar JavaScript + penjelasan + perbandingan PHP"
  },

  "JS - If Statement": {
    "scope": "javascript",
    "prefix": "edu-if",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - IF STATEMENT",
      "// ======================================",
      "let ${1:nilai} = ${2:80};",
      "",
      "if (${1:nilai} > ${3:75}) {",
      "  console.log(\"${4:Lulus}\");",
      "} else {",
      "  console.log(\"${5:Tidak Lulus}\");",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// if digunakan untuk percabangan logika",
      "// kondisi harus bernilai true agar dijalankan",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// Sintaks PHP mirip, tetapi variabel pakai $",
      "// PHP sering menggunakan echo untuk output"
    ],
    "description": "If statement JavaScript + edukasi + perbandingan PHP"
  },

  "JS - Loop For": {
    "scope": "javascript",
    "prefix": "edu-loop-for",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - LOOP FOR",
      "// ======================================",
      "for (let ${1:i} = ${2:0}; ${1:i} < ${3:3}; ${1:i}++) {",
      "  console.log(${1:i});",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// for digunakan untuk perulangan dengan batas tertentu",
      "// terdiri dari inisialisasi, kondisi, increment",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP memiliki struktur yang sama",
      "// perbedaan utama pada variabel ($i) dan output (echo)"
    ],
    "description": "Loop for JavaScript + edukasi + perbandingan PHP"
  },

  "JS - Array Dasar": {
    "scope": "javascript",
    "prefix": "edu-array",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - ARRAY DASAR",
      "// ======================================",
      "let ${1:buah} = [\"${2:apel}\", \"${3:jeruk}\", \"${4:mangga}\"];",
      "",
      "console.log(${1:buah}[0]);",
      "",
      "// menambahkan data",
      "${1:buah}.push(\"${5:pisang}\");",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// array digunakan untuk menyimpan banyak data",
      "// index dimulai dari 0",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP menggunakan array() atau []",
      "// penambahan data menggunakan array_push()"
    ],
    "description": "Array JavaScript + edukasi + perbandingan PHP"
  },

  "JS - Function Dasar": {
    "scope": "javascript",
    "prefix": "edu-func",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - FUNCTION DASAR",
      "// ======================================",
      "function ${1:sapa}(${2:nama}) {",
      "  return \"Halo \" + ${2:nama};",
      "}",
      "",
      "console.log(${1:sapa}(\"${3:Andi}\"));",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// function digunakan untuk membuat blok kode yang bisa dipanggil ulang",
      "// parameter adalah input fungsi",
      "// return mengembalikan nilai",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga menggunakan function",
      "// perbedaan pada penulisan variabel ($nama)"
    ],
    "description": "Function JavaScript + edukasi + perbandingan PHP"
  },

  "JS - Operator Aritmatika": {
    "scope": "javascript",
    "prefix": "edu-operator-arit",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - OPERATOR ARITMATIKA",
      "// ======================================",
      "let ${1:a} = ${2:10};",
      "let ${3:b} = ${4:5};",
      "",
      "console.log(${1:a} + ${3:b}); // penjumlahan",
      "console.log(${1:a} - ${3:b}); // pengurangan",
      "console.log(${1:a} * ${3:b}); // perkalian",
      "console.log(${1:a} / ${3:b}); // pembagian",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// operator aritmatika digunakan untuk operasi matematika",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP memiliki operator yang sama",
      "// perbedaannya hanya pada penulisan variabel ($a, $b)"
    ],
    "description": "Operator aritmatika JavaScript + edukasi + perbandingan PHP"
  },

  "JS - Operator Perbandingan": {
    "scope": "javascript",
    "prefix": "edu-operator-banding",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - OPERATOR PERBANDINGAN",
      "// ======================================",
      "let ${1:a} = ${2:10};",
      "let ${3:b} = \"${4:10}\";",
      "",
      "console.log(${1:a} == ${3:b});  // true (loose)",
      "console.log(${1:a} === ${3:b}); // false (strict)",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// == membandingkan nilai saja",
      "// === membandingkan nilai dan tipe data",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga memiliki == dan ===",
      "// PHP lebih sering terjadi type juggling"
    ],
    "description": "Operator perbandingan JS + edukasi + perbandingan PHP"
  },

  "JS - Operator Logika": {
    "scope": "javascript",
    "prefix": "edu-operator-logika",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - OPERATOR LOGIKA",
      "// ======================================",
      "let ${1:umur} = ${2:20};",
      "let ${3:punyaKTP} = ${4:true};",
      "",
      "console.log(${1:umur} > 17 && ${3:punyaKTP}); // AND",
      "console.log(${1:umur} < 17 || ${3:punyaKTP}); // OR",
      "console.log(!${3:punyaKTP}); // NOT",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// && = dan",
      "// || = atau",
      "// ! = negasi",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga memiliki operator logika yang sama",
      "// sintaks hampir identik"
    ],
    "description": "Operator logika JS + edukasi + perbandingan PHP"
  },

  "JS - Switch Case": {
    "scope": "javascript",
    "prefix": "edu-switch",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - SWITCH CASE",
      "// ======================================",
      "let ${1:hari} = \"${2:Senin}\";",
      "",
      "switch (${1:hari}) {",
      "  case \"${3:Senin}\":",
      "    console.log(\"${4:Hari kerja}\");",
      "    break;",
      "  case \"${5:Minggu}\":",
      "    console.log(\"${6:Hari libur}\");",
      "    break;",
      "  default:",
      "    console.log(\"${7:Hari biasa}\");",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// switch digunakan untuk banyak kondisi",
      "// break mencegah eksekusi ke case berikutnya",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP memiliki struktur switch yang sama",
      "// hanya berbeda pada penulisan variabel ($hari)"
    ],
    "description": "Switch case JS + edukasi + perbandingan PHP"
  },

  "JS - While Loop": {
    "scope": "javascript",
    "prefix": "edu-while",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - WHILE LOOP",
      "// ======================================",
      "let ${1:i} = ${2:0};",
      "",
      "while (${1:i} < ${3:3}) {",
      "  console.log(${1:i});",
      "  ${1:i}++;",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// while akan berjalan selama kondisi true",
      "// cocok untuk kondisi yang belum pasti jumlah perulangannya",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga memiliki while dengan sintaks yang sama",
      "// perbedaan pada variabel ($i) dan output (echo)"
    ],
    "description": "While loop JS + edukasi + perbandingan PHP"
  },

  "JS - Akses Array": {
    "scope": "javascript",
    "prefix": "edu-array-access",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - AKSES ARRAY",
      "// ======================================",
      "let ${1:buah} = [\"apel\", \"jeruk\", \"mangga\"];",
      "",
      "console.log(${1:buah}[${2:1}]);",
      "",
      "// mengubah nilai",
      "${1:buah}[${3:0}] = \"${4:pisang}\";",
      "console.log(${1:buah});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// array diakses menggunakan index (dimulai dari 0)",
      "// nilai array bisa diubah",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga menggunakan index untuk array",
      "// sintaks mirip, tapi variabel menggunakan $"
    ],
    "description": "Akses array JS + edukasi + perbandingan PHP"
  },

  "JS - Push Pop Array": {
    "scope": "javascript",
    "prefix": "edu-array-pushpop",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - PUSH & POP",
      "// ======================================",
      "let ${1:angka} = [${2:1}, ${3:2}, ${4:3}];",
      "",
      "${1:angka}.push(${5:4}); // tambah di akhir",
      "console.log(${1:angka});",
      "",
      "${1:angka}.pop(); // hapus dari akhir",
      "console.log(${1:angka});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// push menambah elemen",
      "// pop menghapus elemen terakhir",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP menggunakan array_push()",
      "// dan array_pop()"
    ],
    "description": "Push & Pop array JS + edukasi + perbandingan PHP"
  },

  "JS - Loop Array forEach": {
    "scope": "javascript",
    "prefix": "edu-array-foreach",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - LOOP ARRAY (forEach)",
      "// ======================================",
      "let ${1:buah} = [\"apel\", \"jeruk\", \"mangga\"];",
      "",
      "${1:buah}.forEach(function(${2:item}) {",
      "  console.log(${2:item});",
      "});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// forEach digunakan untuk looping array",
      "// lebih sederhana dibanding for",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP menggunakan foreach untuk array",
      "// konsep sama, sintaks berbeda"
    ],
    "description": "Loop array forEach JS + edukasi + perbandingan PHP"
  },

  "JS - Function Return": {
    "scope": "javascript",
    "prefix": "edu-func-return",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - FUNCTION RETURN",
      "// ======================================",
      "function ${1:tambah}(${2:a}, ${3:b}) {",
      "  return ${2:a} + ${3:b};",
      "}",
      "",
      "let ${4:hasil} = ${1:tambah}(${5:5}, ${6:3});",
      "console.log(${4:hasil});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// parameter = input fungsi",
      "// return = nilai yang dikembalikan",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga menggunakan return",
      "// perbedaan pada variabel ($a, $b)"
    ],
    "description": "Function return JS + edukasi + perbandingan PHP"
  },

  "JS - Arrow Function": {
    "scope": "javascript",
    "prefix": "edu-arrow",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - ARROW FUNCTION",
      "// ======================================",
      "const ${1:tambah} = (${2:a}, ${3:b}) => {",
      "  return ${2:a} + ${3:b};",
      "};",
      "",
      "console.log(${1:tambah}(${4:2}, ${5:3}));",
      "",
      "// versi singkat (implicit return)",
      "const ${6:kali} = (${2:a}, ${3:b}) => ${2:a} * ${3:b};",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// arrow function = cara singkat menulis function",
      "// sering digunakan di JavaScript modern",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP tidak memiliki arrow function seperti ini",
      "// PHP lebih menggunakan function biasa"
    ],
    "description": "Arrow function JS + edukasi + perbandingan PHP"
  },

  "JS - Tipe Data": {
    "scope": "javascript",
    "prefix": "edu-datatype",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - TIPE DATA",
      "// ======================================",
      "let ${1:angka} = ${2:10};       // number",
      "let ${3:teks} = \"${4:Halo}\";   // string",
      "let ${5:benar} = ${6:true};     // boolean",
      "let ${7:kosong} = null;         // null",
      "",
      "console.log(typeof ${1:angka});",
      "console.log(typeof ${3:teks});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// JavaScript memiliki tipe data dinamis",
      "// typeof digunakan untuk mengecek tipe data",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga dynamic typing",
      "// menggunakan gettype() untuk cek tipe data"
    ],
    "description": "Tipe data JS + edukasi + perbandingan PHP"
  },

  "JS - Do While": {
    "scope": "javascript",
    "prefix": "edu-do-while",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - DO WHILE",
      "// ======================================",
      "let ${1:i} = ${2:0};",
      "",
      "do {",
      "  console.log(${1:i});",
      "  ${1:i}++;",
      "} while (${1:i} < ${3:3});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// do while dijalankan minimal 1 kali",
      "// kondisi dicek setelah eksekusi",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP memiliki struktur do while yang sama",
      "// hanya berbeda pada sintaks variabel"
    ],
    "description": "Do while JS + edukasi + perbandingan PHP"
  },

  "JS - Break Continue": {
    "scope": "javascript",
    "prefix": "edu-break-continue",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - BREAK & CONTINUE",
      "// ======================================",
      "for (let ${1:i} = 0; ${1:i} < ${2:5}; ${1:i}++) {",
      "  if (${1:i} === ${3:2}) continue; // skip angka ${3:2}",
      "  if (${1:i} === ${4:4}) break;    // berhenti di ${4:4}",
      "  console.log(${1:i});",
      "}",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// continue: melewati iterasi tertentu",
      "// break: menghentikan loop",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP juga memiliki break & continue",
      "// konsep dan penggunaan sama"
    ],
    "description": "Break & continue JS + edukasi + perbandingan PHP"
  },

  "JS - Object Dasar": {
    "scope": "javascript",
    "prefix": "edu-object",
    "body": [
      "// ======================================",
      "// JAVASCRIPT - OBJECT DASAR",
      "// ======================================",
      "let ${1:user} = {",
      "  ${2:nama}: \"${3:Andi}\",",
      "  ${4:umur}: ${5:20}",
      "};",
      "",
      "console.log(${1:user}.${2:nama});",
      "",
      "// ======================================",
      "// PENJELASAN",
      "// ======================================",
      "// object menyimpan data dalam bentuk key-value",
      "// digunakan untuk representasi data kompleks",
      "",
      "// ======================================",
      "// PERBANDINGAN DENGAN PHP",
      "// ======================================",
      "// PHP menggunakan associative array",
      "// contoh: ['nama' => 'Andi']"
    ],
    "description": "Object dasar JS + edukasi + perbandingan PHP"
  }
}
