{
  "Compare Variable (JS vs PHP)": {
    "scope": "javascript,php",
    "prefix": "edu-compare-var",
    "body": [
      "// ======================================",
      "// PERBANDINGAN VARIABEL",
      "// ======================================",
      "",
      "// JavaScript:",
      "// let nama = \"Andi\";   // bisa diubah",
      "// const umur = 20;      // tidak bisa diubah",
      "// var lama = \"hindari\"; // cara lama, hindari",
      "",
      "// PHP:",
      "// $nama = \"Andi\";  // selalu pakai $",
      "// $umur = 20;       // tidak ada const untuk variabel biasa",
      "// define('PI', 3.14); // konstanta pakai define()",
      "",
      "// Kesimpulan:",
      "// JS: let/const membedakan mutable vs immutable",
      "// PHP: semua variabel pakai $, konstanta pakai define()"
    ],
    "description": "Perbandingan variabel JS vs PHP"
  },

  "Compare Datatype (JS vs PHP)": {
    "scope": "javascript,php",
    "prefix": "edu-compare-datatype",
    "body": [
      "// ======================================",
      "// PERBANDINGAN TIPE DATA",
      "// ======================================",
      "",
      "// JavaScript:",
      "// let x = 10;        // number (int & float jadi satu)",
      "// let y = \"Halo\";   // string",
      "// let z = true;      // boolean",
      "// typeof x;          // cek tipe: \"number\"",
      "",
      "// PHP:",
      "// $x = 10;           // integer",
      "// $y = 3.14;         // float (berbeda dari integer!)",
      "// $z = \"Halo\";      // string",
      "// $w = true;         // boolean",
      "// gettype($x);       // cek tipe: \"integer\"",
      "// var_dump($x);      // detail: int(10)",
      "",
      "// Kesimpulan:",
      "// JS: number mencakup int & float sekaligus",
      "// PHP: integer dan float adalah tipe berbeda"
    ],
    "description": "Perbandingan tipe data JS vs PHP"
  },

  "Compare Operator (JS vs PHP)": {
    "scope": "javascript,php",
    "prefix": "edu-compare-operator",
    "body": [
      "// ======================================",
      "// PERBANDINGAN OPERATOR",
      "// ======================================",
      "",
      "// JavaScript:",
      "// 10 == \"10\"   // true  (loose, tipe diabaikan)",
      "// 10 === \"10\"  // false (strict, tipe diperiksa)",
      "// 10 !== \"10\"  // true  (strict not equal)",
      "",
      "// PHP:",
      "// 10 == \"10\"   // true  (loose, type juggling)",
      "// 10 === \"10\"  // false (strict)",
      "// 0 == \"a\"     // true! (hati-hati di PHP lama)",
      "",
      "// Kesimpulan:",
      "// Selalu gunakan === di kedua bahasa",
      "// PHP lebih rawan type juggling, terutama versi lama"
    ],
    "description": "Perbandingan operator JS vs PHP"
  },

  "Compare IF JS vs PHP (Logic)": {
  "prefix": "edu-compare-if",
  "body": [
    "// =========================================",
    "// JAVASCRIPT",
    "// =========================================",
    "let nilai = 80;",
    "",
    "if (nilai >= 75) {",
    "  console.log('Lulus');",
    "} else {",
    "  console.log('Tidak Lulus');",
    "}",
    "",
    "// =========================================",
    "// PHP",
    "// =========================================",
    "$nilai = 80;",
    "",
    "if ($nilai >= 75) {",
    "  echo 'Lulus';",
    "} else {",
    "  echo 'Tidak Lulus';",
    "}",
    "",
    "// =========================================",
    "// PERBEDAAN UTAMA",
    "// =========================================",
    "// JS  → output: console.log()",
    "// PHP → output: echo",
    "",
    "// =========================================",
    "// ⚠️ COMMON MISTAKE",
    "// =========================================",
    "// JS → if (x = 5) salah (assignment, bukan perbandingan)",
    "// PHP → lupa tanda $",
    "",
    "// =========================================",
    "// 💡 BEST PRACTICE",
    "// =========================================",
    "// Gunakan === untuk perbandingan ketat",
    "// Hindari nested if terlalu dalam"
  ],
  "description": "Compare IF JS vs PHP dengan best practice"
  },

  "Compare Switch (JS vs PHP)": {
    "scope": "javascript,php",
    "prefix": "edu-compare-switch",
    "body": [
      "// ======================================",
      "// PERBANDINGAN SWITCH",
      "// ======================================",
      "",
      "// JavaScript:",
      "// switch (hari) {",
      "//   case \"Senin\":",
      "//     console.log(\"Kerja\");",
      "//     break;   // wajib! tanpa ini lanjut ke case bawah",
      "//   default:",
      "//     console.log(\"Hari lain\");",
      "// }",
      "",
      "// PHP:",
      "// switch ($hari) {",
      "//   case \"Senin\":",
      "//     echo \"Kerja\";",
      "//     break;   // sama, wajib juga",
      "//   default:",
      "//     echo \"Hari lain\";",
      "// }",
      "",
      "// Kesimpulan:",
      "// Struktur hampir identik",
      "// Perbedaan hanya pada variabel ($) dan output (echo vs console.log)"
    ],
    "description": "Perbandingan switch JS vs PHP"
  },

  "Compare Loop (JS vs PHP)": {
    "scope": "javascript,php",
    "prefix": "edu-compare-loop",
    "body": [
      "// ======================================",
      "// PERBANDINGAN LOOP",
      "// ======================================",
      "",
      "// JavaScript — for:",
      "// for (let i = 0; i < 3; i++) { console.log(i); }",
      "",
      "// PHP — for:",
      "// for ($i = 0; $i < 3; $i++) { echo $i; }",
      "",
      "// JavaScript — forEach (khusus array):",
      "// [1,2,3].forEach(item => console.log(item));",
      "",
      "// PHP — foreach (khusus array):",
      "// foreach ([1,2,3] as $item) { echo $item; }",
      "",
      "// Kesimpulan:",
      "// for: sintaks identik, beda di variabel ($) dan output",
      "// JS punya forEach (method), PHP punya foreach (keyword)"
    ],
    "description": "Perbandingan loop JS vs PHP"
  },

  "Compare Break Continue": {
    "scope": "javascript,php",
    "prefix": "edu-compare-break",
    "body": [
      "// ======================================",
      "// PERBANDINGAN BREAK & CONTINUE",
      "// ======================================",
      "",
      "// JavaScript:",
      "// for (let i = 0; i < 5; i++) {",
      "//   if (i === 2) continue; // skip i=2",
      "//   if (i === 4) break;    // stop di i=4",
      "//   console.log(i); // output: 0, 1, 3",
      "// }",
      "",
      "// PHP:",
      "// for ($i = 0; $i < 5; $i++) {",
      "//   if ($i === 2) continue;",
      "//   if ($i === 4) break;",
      "//   echo $i; // output: 0, 1, 3",
      "// }",
      "// PHP bonus: break 2; untuk keluar dari nested loop",
      "",
      "// Kesimpulan:",
      "// Fungsi identik di kedua bahasa",
      "// PHP punya keunggulan: break N untuk nested loop"
    ],
    "description": "Perbandingan break & continue JS vs PHP"
  },

  "Compare Array": {
    "scope": "javascript,php",
    "prefix": "edu-compare-array",
    "body": [
      "// ======================================",
      "// PERBANDINGAN ARRAY",
      "// ======================================",
      "",
      "// JavaScript:",
      "// let buah = [\"apel\", \"jeruk\"];",
      "// buah.push(\"mangga\");    // tambah",
      "// buah.pop();             // hapus terakhir",
      "// buah.length;            // panjang array",
      "// buah[0];                // akses index",
      "",
      "// PHP:",
      "// $buah = [\"apel\", \"jeruk\"];",
      "// array_push($buah, \"mangga\"); // tambah",
      "// array_pop($buah);            // hapus terakhir",
      "// count($buah);               // panjang array",
      "// $buah[0];                   // akses index",
      "",
      "// Kesimpulan:",
      "// JS: array punya method langsung (.push, .pop, .length)",
      "// PHP: menggunakan fungsi terpisah (array_push, count)"
    ],
    "description": "Perbandingan array JS vs PHP"
  },

  "Compare Function": {
    "scope": "javascript,php",
    "prefix": "edu-compare-func",
    "body": [
      "// ======================================",
      "// PERBANDINGAN FUNCTION",
      "// ======================================",
      "",
      "// JavaScript — regular:",
      "// function sapa(nama) { return \"Halo \" + nama; }",
      "",
      "// JavaScript — arrow:",
      "// const sapa = (nama) => \"Halo \" + nama;",
      "",
      "// PHP — regular:",
      "// function sapa($nama) { return \"Halo \" . $nama; }",
      "",
      "// PHP — arrow (sejak PHP 7.4):",
      "// $sapa = fn($nama) => \"Halo \" . $nama;",
      "",
      "// Kesimpulan:",
      "// Konsep sama, perbedaan utama:",
      "// JS: + untuk string, PHP: . untuk string",
      "// JS arrow: =>, PHP arrow: fn() =>"
    ],
    "description": "Perbandingan function JS vs PHP"
  },

  "Compare Object": {
    "scope": "javascript,php",
    "prefix": "edu-compare-object",
    "body": [
      "// ======================================",
      "// PERBANDINGAN OBJECT vs ASSOCIATIVE ARRAY",
      "// ======================================",
      "",
      "// JavaScript — object:",
      "// let user = { nama: \"Andi\", umur: 20 };",
      "// user.nama;        // akses dengan dot",
      "// user[\"nama\"];    // akses dengan bracket",
      "// user.alamat = \"Jakarta\"; // tambah property",
      "",
      "// PHP — associative array:",
      "// $user = [\"nama\" => \"Andi\", \"umur\" => 20];",
      "// $user[\"nama\"];   // akses dengan key",
      "// $user[\"alamat\"] = \"Jakarta\"; // tambah elemen",
      "",
      "// Kesimpulan:",
      "// JS: object adalah tipe data native, bisa pakai dot notation",
      "// PHP: tidak ada object literal, pakai associative array"
    ],
    "description": "Perbandingan object JS vs associative array PHP"
  },

  "Compare Output": {
    "scope": "javascript,php",
    "prefix": "edu-compare-output",
    "body": [
      "// ======================================",
      "// PERBANDINGAN OUTPUT",
      "// ======================================",
      "",
      "// JavaScript:",
      "// console.log(\"Halo\");       // ke console browser/Node",
      "// console.log(nama, umur);   // bisa banyak nilai",
      "// alert(\"Halo\");            // popup (browser only)",
      "",
      "// PHP:",
      "// echo \"Halo\";              // ke halaman web",
      "// echo $nama . \" \" . $umur; // gabung dengan .",
      "// print \"Halo\";             // mirip echo, lebih lambat",
      "// var_dump($x);             // debug: tampil tipe + nilai",
      "// print_r($array);          // debug: tampil isi array",
      "",
      "// Kesimpulan:",
      "// JS console.log untuk debug, PHP echo untuk render HTML",
      "// PHP punya var_dump & print_r khusus debugging"
    ],
    "description": "Perbandingan output JS vs PHP"
  },

  "Compare Execution": {
    "scope": "javascript,php",
    "prefix": "edu-compare-exec",
    "body": [
      "// ======================================",
      "// PERBANDINGAN EKSEKUSI",
      "// ======================================",
      "",
      "// JavaScript:",
      "// - Berjalan di BROWSER (client-side)",
      "// - Bisa juga di server via Node.js",
      "// - File: .js",
      "// - Tidak perlu tag pembuka/penutup",
      "// - Contoh: script.js → langsung jalan di browser",
      "",
      "// PHP:",
      "// - Berjalan di SERVER (server-side)",
      "// - Browser hanya menerima hasil HTML-nya",
      "// - File: .php",
      "// - Wajib diawali <?php dan diakhiri ?>",
      "// - Contoh: index.php → diproses server → HTML dikirim ke browser",
      "",
      "// Kesimpulan:",
      "// JS: kode dieksekusi di komputer pengguna (browser)",
      "// PHP: kode dieksekusi di server, pengguna tidak lihat kodenya"
    ],
    "description": "Perbandingan eksekusi JS vs PHP"
  }
}
